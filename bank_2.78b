        data forest_rooms
        00, 00, 25, 26,  8, 00, 00,
        00, 11, 12, 03, 06, 29, 29,
        30,  9, 11, 07, 02, 12, 00,
        24, 10, 01, 04, 05, 31, 31,
        00, 00, 17, 15, 18, 00, 00,
        00, 00, 16, 13, 14, 00, 00,
        21, 22, 20, 19, 23, 00, 00
end

test_walkable_forest
        tile_properties_1 = forest_tile_properties[move_tile_1]
        tile_properties_2 = forest_tile_properties[move_tile_2]
        ; if Johanna has the Nix's Tail relic, make shorelines walkable
        if !index && m_relic_bits_2{0} then gosub walkable_water_forest
        goto walkable_return

walkable_water_forest
        ; non-shoreline water is always walkable, this tests unwalkable tiles flagged as water
        if tile_properties_1{2} then tile_properties_1{0} = 1
walkable_water_forest_tile_2
        ; test if tile is a waterfall, which is never made walkable
        if tile_properties_2{7} then walkable_water_forest_done
        if tile_properties_2{2} then tile_properties_2{0} = 1
walkable_water_forest_done

        ; objects can call this part of the subroutine to test if they are in water
test_water_forest
        ; water is tested differently than other properties, it tests the tile directly under the object
        ; this helps eliminate graphical issues when approaching a non-water tile in water
        gosub get_object_pos
        temp1 = peekchar (current_map, peekX, peekY, 20, 14)
        temp1 = temp1 / 2
        temp1 = forest_tile_properties[temp1]
        asm
          ldx index
          lda temp1
          and #%00000100
          beq test_water_forest_land
          lda object_flags,x
          ora #%00000010
          jmp test_water_forest_done
test_water_forest_land
          lda object_flags,x
          and #%11111101
test_water_forest_done
          sta object_flags,x
          rts
end

        ; %00000001 = walkable
        ; %00000010 = floatable
        ; %00000100 = water
        ; %00001000 = unused (shore)
        ; %00010000 = ledge - hop down
        ; %00100000 = ledge - hop right
        ; %01000000 = ledge - hop left
        ; %10000000 = waterfall
        data forest_tile_properties
        %00000011, %00000011, %00000011, %00000000, %00000000, %00000000, %00000000, %00000011,
        %00000000, %00000011, %00000011, %00000011, %00000011, %00000011, %00000011, %00000011,
        %00000011, %00000011,
                              %00010010, %00010010, %00010010, %00000000, %00000010, %00100010,
        %00100010, %00100010, %01000010, %01000010, %01000010,
                                                               %00000110, %00000111, %00000110,
        %00000000, %00000110, %00000110, %00000110, %00000110, %00000110, %00000110, %00000000,
        %00000000, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000,
        %00000000, %00000001, %00000000, %00000000,
                                                    %00000011, %00000011, %00000011, %00000011,
        %00000011, %00000011, %00000011, %00000011, %00000011,
                                                               %00000000, %00000000, %00000000,
        %00000001, %00000001, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000,
        %00000000, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000,
        %00000011, %00000010, %00000010, %00000010, %00000010,
                                                               %00000011, %00000011, %00000000,
        %00000000, %00000000, %00000000, %00000000, %00000000, %00000000, %00000000,
                                                                                     %10000100
end

torch_tile_block_forest
        ; block with a floatable tile so projectiles can hit torch
        pokechar current_map peekX peekY 20 14 $2C
        if object_type[index] <> TYPE_DOOR_LOCK then goto torch_tile_block_set_flag
        ; doors need to block a second tile to the right of the first
        peekX = peekX + 1
        pokechar current_map peekX peekY 20 14 $2C
        goto torch_tile_block_set_flag

torch_tile_unblock_forest
        ; the poked tile doesn't affect visuals since those are plotted from ROM
        pokechar current_map peekX peekY 20 14 0
        goto kill_torch_done

burnbush_check
        ; this check comes from magic_collision.asm
        ; X = player's projectile Y = object index
        asm
          lda object_type,x
          cmp #TYPE_FIREBALL
          beq burnbush_set_bits
          cmp #TYPE_LIGHTNING
          beq burnbush_set_bits
          jmp .magic_damage_immune
burnbush_set_bits
          ; set flag to remove bush
          lda #STATE_BURNBUSH_BURN
          sta object_state,y 
          jmp .magic_damage_immune
end

;==============================================================================
; WOLF AI
;------------------------------------------------------------------------------
; Wolves wait for the player to get close (WOLF_CHASE_DIST), then give chase
;==============================================================================
wolf_ai
        ; Once wolves start chasing, they don't stop
        asm
          lda object_Xpos,x
          cmp player_Xpos
          bcc wolf_right
          lda #F_WOLF_LEFT_1
          sta object_frame,x
          jmp wolf_anim
wolf_right
          lda #F_WOLF_RIGHT_1
          sta object_frame,x
wolf_anim
          lda animation_frame
          bne wolf_flags
          inc object_frame,x
wolf_flags
          lda object_flags,x
          cmp #%10000000
          beq wolf_chase
          lda object_Xpos,x
          sec
          sbc #WOLF_CHASE_OFFSET_X
          sta Xposition
          lda object_Ypos,x
          sec
          sbc #WOLF_CHASE_OFFSET_Y
          sta Yposition
end
        if !boxcollision(player_Xpos, player_Ypos, PLAYER_WIDTH, PLAYER_HEIGHT, Xposition, Yposition, WOLF_CHASE_DIST_X, WOLF_CHASE_DIST_Y) then return thisbank
        asm
          lda object_flags,x
          ora #%10000000
          sta object_flags,x

wolf_chase
          jmp .follow_player
end

obj_wolf_stats
; TODO: Make this implementation suck less
        object_hp[obj_index] = WOLF_HP
        object_vel_cap_hi[obj_index] = WOLF_VEL_CAP_HI
        object_vel_cap_lo[obj_index] = WOLF_VEL_CAP_LO
        object_damage[obj_index] = WOLF_DAMAGE
        object_def[obj_index] = WOLF_DEF
        object_mdef[obj_index] = WOLF_MDEF
        object_friction_hi[obj_index] = WOLF_FRICTION_HI
        object_friction_lo[obj_index] = WOLF_FRICTION_LO
        object_speed_hi[obj_index] = WOLF_SPEED_HI
        object_speed_lo[obj_index] = WOLF_SPEED_LO
        object_flags[obj_index] = 0
        asm
          ldx obj_index
          lda #WOLF_PAL
          sta object_pal,x
          lda #<.plot_forest_160a
          sta object_spr_ptr_lo,x
          lda #>.plot_forest_160a
          sta object_spr_ptr_hi,x
end
        goto obj_next_stats

;==============================================================================
; SLIME AI
;------------------------------------------------------------------------------
; A Slime draws near!
; Command?
;==============================================================================
mslime_ai
        asm
          lda #F_MSLIME_1
          sta object_frame,x
          lda #MSLIME_DEF
          jmp slime_anim

.slime_ai
          lda #F_SLIME_1
          sta object_frame,x
          lda #SLIME_DEF

slime_anim
          sta object_def,x
          lda animation_frame
          beq slime_chase
          lda #0
          sta object_def,x
          inc object_frame,x
slime_chase
          jmp .follow_player
end

obj_slime_stats
        object_hp[obj_index] = SLIME_HP
        object_vel_cap_hi[obj_index] = SLIME_VEL_CAP_HI
        object_vel_cap_lo[obj_index] = SLIME_VEL_CAP_LO
        object_damage[obj_index] = SLIME_DAMAGE
        object_def[obj_index] = SLIME_DEF
        object_mdef[obj_index] = SLIME_MDEF
        object_friction_hi[obj_index] = SLIME_FRICTION_HI
        object_friction_lo[obj_index] = SLIME_FRICTION_LO
        object_speed_hi[obj_index] = SLIME_SPEED_HI
        object_speed_lo[obj_index] = SLIME_SPEED_LO
        object_flags[obj_index] = 0
        asm
          ldx obj_index
          lda #SLIME_PAL
          sta object_pal,x
end
        goto obj_forest_160a

split_slime
        ; replace slime mobj with mini slime
        asm
          ldx index
          lda #TYPE_MSLIME
          sta object_type,x
          lda #MSLIME_HP
          sta object_hp,x
          lda #MSLIME_DEF
          sta object_def,x
          lda #<.plot_forest_160a
          sta object_spr_ptr_lo,x
          lda #>.plot_forest_160a
          sta object_spr_ptr_hi,x
          lda #F_MSLIME_1
          sta object_frame,x
end
        gosub find_new_object
        ; if no slots, the slime just becomes a single mini slime
        if no_empty_slot then goto set_enemy_name
        asm
          ; move the original slime to the left
          ldx index
          lda object_Xpos,x
          ; push Xpos to stack for later use
          pha
          dec object_Xpos,x
          lda object_Ypos,x
        ; initialize the new mini slime object
          ldx spawn_index
          sta object_Ypos,x
          lda #TYPE_MSLIME
          sta object_type,x
          lda #MSLIME_HP
          sta object_hp,x
          lda #SLIME_VEL_CAP_HI
          sta object_vel_cap_hi,x
          lda #SLIME_VEL_CAP_LO
          sta object_vel_cap_lo,x
          lda #SLIME_DAMAGE
          sta object_damage,x
          lda #SLIME_DEF
          sta object_def,x
          lda #SLIME_MDEF
          sta object_mdef,x
          lda #SLIME_FRICTION_HI
          sta object_friction_hi,x
          lda #SLIME_FRICTION_LO
          sta object_friction_lo,x
          lda #SLIME_SPEED_HI
          sta object_speed_hi,x
          lda #SLIME_SPEED_LO
          sta object_speed_lo,x
          lda #F_MSLIME_1
          sta object_frame,x
          lda #SLIME_PAL
          sta object_pal,x
          lda #0
          sta object_invuln,x
          sta object_flags,x
          ; pull parent X position from stack and move spawned slime to the right
          pla
          clc
          adc #9
          sta object_Xpos,x
          lda #<.plot_forest_160a
          sta object_spr_ptr_lo,x
          lda #>.plot_forest_160a
          sta object_spr_ptr_hi,x
end
        goto set_enemy_name

;==============================================================================
; RAVEN AI
;------------------------------------------------------------------------------
; Flies without testing walkability and perches on trees
;==============================================================================
raven_ai
        asm
          lda object_flags,x
          and #%10000000
          beq raven_set_face
          jmp raven_move
raven_set_face
          lda player_Xpos
          cmp object_Xpos,x
          bcs raven_face_right
raven_face_left
          lda #F_RAVEN_PIRCH_L
          sta object_frame,x
          jmp raven_set_dir
raven_face_right
          lda #F_RAVEN_PIRCH_R
          sta object_frame,x

raven_set_dir
          lda object_Xpos,x
          cmp #80
          bcs raven_move_left
raven_move_right
          lda #DIR_RIGHT
          bne raven_Xdir
raven_move_left
          lda #DIR_LEFT
raven_Xdir
          sta object_facing,x
          sta object_Xdir,x

test_dist_to_player
          lda object_Xpos,x
          sec
          sbc player_Xpos
          bvc raven_test_dist_to_player
          ora #$FF
          clc
          adc #1
raven_test_dist_to_player
          cmp #RAVEN_CHASE_DIST
          bcs raven_change_pos
          rts

raven_change_pos
          lda object_flags,x
          ora #%10000000
          sta object_flags,x
          lda #RAVEN_FLIGHT_TIME
          sta object_timer,x
          lda player_Ypos
          cmp object_Ypos,x
          bcc raven_swoop_up
raven_swoop_down
          lda #DIR_DOWN
          sta object_Ydir,x
          bne raven_speed
raven_swoop_up
          lda #DIR_UP
          sta object_Ydir,x
raven_speed
          lda object_speed_hi,x
          sta object_Xvel_hi,x
          lda object_speed_lo,x
          sta object_Xvel_lo,x
          lda #0
          sta object_Yvel_hi,x
          lda #128
          sta object_Yvel_lo,x
raven_move
raven_anim
          lda object_Xdir,x
          cmp #DIR_LEFT
          beq raven_anim_left
raven_anim_right
          lda #F_RAVEN_FLY_R_1
          jmp raven_anim_frame
raven_anim_left
          lda #F_RAVEN_FLY_L_1
raven_anim_frame
          sta object_frame,x
          lda animation_frame
          bne raven_timer
          inc object_frame,x
          inc object_frame,x
raven_timer
          dec object_timer,x
          beq raven_flight_reverse
          cmp #RAVEN_FLIGHT_TIME/2
          bcc raven_swoop_up_speed
raven_swoop_down_speed
          lda object_Yvel_lo,x
          clc
          adc #RAVEN_SWOOP_SPEED
          sta object_Yvel_lo,x
          lda object_Yvel_hi,x
          adc #0
          sta object_Yvel_hi,x
          rts
raven_swoop_up_speed
          lda object_Yvel_lo,x
          sec
          sbc #RAVEN_SWOOP_SPEED
          sta object_Yvel_lo,x
          lda object_Yvel_hi,x
          sbc #0
          sta object_Yvel_hi,x
          rts
raven_flight_reverse
          lda #RAVEN_FLIGHT_TIME
          sta object_timer,x
          lda object_Xdir,x
          cmp #DIR_LEFT
          beq raven_fly_right
          lda #DIR_LEFT
          sta object_Xdir,x
          bne raven_flight_reverse_vert
raven_fly_right
          lda #DIR_RIGHT
          sta object_Xdir,x
raven_flight_reverse_vert
          lda object_Ydir,x
          cmp #DIR_UP
          beq raven_fly_down
raven_fly_up
          lda #DIR_UP
          sta object_Ydir,x
          rts
raven_fly_down
          lda #DIR_DOWN
          sta object_Ydir,x
          rts
end

obj_raven_stats
        asm
          ldx obj_index
          lda #RAVEN_HP
          sta object_hp,x
          lda #RAVEN_VEL_CAP_HI
          sta object_vel_cap_hi,x
          lda #RAVEN_VEL_CAP_LO
          sta object_vel_cap_lo,x
          lda #RAVEN_DAMAGE
          sta object_damage,x
          lda #RAVEN_DEF
          sta object_def,x
          lda #RAVEN_MDEF
          sta object_mdef,x
          lda #RAVEN_FRICTION_HI
          sta object_friction_hi,x
          lda #RAVEN_FRICTION_LO
          sta object_friction_lo,x
          lda #RAVEN_SPEED_HI
          sta object_speed_hi,x
          lda #RAVEN_SPEED_LO
          sta object_speed_lo,x
          lda #%00000100
          sta object_flags,x
          lda #RAVEN_PAL
          sta object_pal,x
          jmp .obj_forest_160a
end

;==============================================================================
; FOREST GHOST AI
;------------------------------------------------------------------------------
; Floats through walls to attack player
;==============================================================================
fghost_ai
        asm
          lda #FGHOST_PAL_1
          sta object_pal,x
          lda #F_FGHOST_1
          sta object_frame,x
          lda animation_frame
          bne fghost_follow
          lda #FGHOST_PAL_2
          sta object_pal,x
          inc object_frame,x
fghost_follow
          jmp .test_follow_box
end

obj_fghost_stats
        asm
          ldx obj_index
          lda #FGHOST_HP
          sta object_hp,x
          lda #FGHOST_VEL_CAP_HI
          sta object_vel_cap_hi,x
          lda #FGHOST_VEL_CAP_LO
          sta object_vel_cap_lo,x
          lda #FGHOST_DAMAGE
          sta object_damage,x
          lda #FGHOST_DEF
          sta object_def,x
          lda #FGHOST_MDEF
          sta object_mdef,x
          lda #FGHOST_FRICTION_HI
          sta object_friction_hi,x
          lda #FGHOST_FRICTION_LO
          sta object_friction_lo,x
          lda #FGHOST_SPEED_HI
          sta object_speed_hi,x
          lda #FGHOST_SPEED_LO
          sta object_speed_lo,x
          lda #FGHOST_FLAGS
          sta object_flags,x
          lda #FGHOST_PAL_1
          sta object_pal,x
          lda #F_FGHOST_1
          sta object_frame,x
          lda #FGHOST_PAL_1
          lda #<.plot_forest_160a
          sta object_spr_ptr_lo,x
          lda #>.plot_forest_160a
          sta object_spr_ptr_hi,x
end
        goto obj_next_stats

firebat_ai
        asm
          lda object_flags+1
          cmp #%01010000
          beq firebat_rise
          cmp #%10010000
          beq firebat_attack
          lda object_flags+2
          cmp #%10000000
          beq firebat_init
          rts

firebat_init
          lda object_Ypos+1
          cmp #$80
          bcc firebat_rise
          lda #$68
          sta object_Ypos+1
          lda #50
          sta object_invuln+1
          lda #%01010000
          sta object_flags+1

firebat_rise
          lda object_Ypos+1
          cmp #$39
          bcc firebat_attack
          lda #DIR_UP
          sta object_Ydir+1
          lda #FIREBAT_SPEED_LO
          sta object_Yvel_lo+1
          lda #FIREBAT_SPEED_HI
          sta object_Yvel_hi+1
          lda #0
          sta object_Xvel_lo+1
          sta object_Xvel_hi+1
          sta object_timer+1
          rts

firebat_timer_init
          lda #FIREBAT_SWOOP_FRAMES
          sta object_timer+1

firebat_attack
          lda player_Ypos
          clc
          adc #16
          cmp object_Ypos+1
          bcs firebat_attack_timer
          ; if player is above bat, bat rises
          lda #%01010000
          sta object_flags+1
          rts
firebat_attack_timer
          lda #%10010000
          sta object_flags+1
          dec object_timer+1
          bmi firebat_timer_init
          bne firebat_return
          lda #DIR_DOWN
          sta object_Ydir+1
          lda #2
          sta object_Xvel_hi+1
          sta object_Yvel_hi+1
          lda #FIREBAT_SPEED_LO
          sta object_Xvel_lo+1
          sta object_Yvel_lo+1
          lda #STATE_MOVING
          sta object_state+1
          jsr randomize
          cmp #85
          bcc firebat_move_right
          cmp #170
          bcs firebat_return

firebat_move_left
          lda #DIR_LEFT
          sta object_Xdir+1
          rts

firebat_move_right
          lda #DIR_RIGHT
          sta object_Xdir+1
firebat_return
          rts
          
firebat_fireball
          jsr .find_new_object
          lda no_empty_slot
          beq firebat_prep_ball
          rts

firebat_prep_ball
          rts
end

forest_boss_ai
        asm
          lda m_spell_bits_1
          and #%00000001
          bne forest_boss_beat
          lda object_flags,x
          cmp #%10000000
          beq forest_boss_check
          lda player_Ypos
          cmp #$90
          bcs forest_boss_return
          lda #TYPE_BOSS_FLAME
          sta object_type+5
          sta object_type+6
          lda #72
          sta object_Xpos+5
          lda #80
          sta object_Xpos+6
          lda #$B0
          sta object_Ypos+5
          sta object_Ypos+6
;         lda #F_FLAME
;         sta object_frame+5
;         sta object_frame+6
;         lda #2
;         sta object_pal+5
;         sta object_pal+6
          lda #%10000000
          sta object_flags,x
forest_boss_return
          rts

forest_boss_beat
          lda #0
          sta object_type+1
          sta object_type+2
          beq forest_boss_dead

forest_boss_check
          lda object_type+1
          bne forest_boss_return
          lda #TYPE_SPELL1
          sta object_type+2

forest_boss_dead
          lda #0
          sta object_type+5
          sta object_type+6
          lda #$60
          sta object_Ypos+2
end
forest_flame_unblock
        pokechar current_map  9 11 20 14 0
        pokechar current_map 10 11 20 14 0
        pokechar current_map  9 10 20 14 0
        pokechar current_map 10 10 20 14 0
        if m_spell_bits_1{0} then return thisbank
        playsfx sfx_crystalchimes
        return thisbank

; mini trees that block progression to force player to try magic
burnbush_ai
        asm
          ; use state instead of flags because torch tile block resets flags
          lda object_state,x
          cmp #STATE_BURNBUSH_BURN
          bne burnbush_block

burnbush_burn
          dec object_timer,x
          bmi burnbush_timer
          beq burnbush_unblock
          lda #F_FLAME
          sta object_frame,x
          lda animation_frame
          beq burnbush_block
          inc object_frame,x

burnbush_block
          ; just run this every frame because of menu access
          jsr .get_object_pos
          jmp .torch_tile_block_forest

burnbush_unblock
          lda #0
          sta object_type,x
          jsr .get_object_pos
          jmp .torch_tile_unblock_forest

burnbush_timer
          lda #BURNBUSH_BURN_TIME
          sta object_timer,x
          lda #FIRE_PAL
          sta object_pal,x
          lda #<.plot_food
          sta object_spr_ptr_lo,x
          lda #>.plot_food
          sta object_spr_ptr_hi,x
          lda #F_FLAME
          sta object_frame,x
          rts
end

obj_burnbush_stats
        asm
          ldx obj_index
          lda #1
          sta object_hp,x
          lda #255
          sta object_def,x
          sta object_mdef,x
          lda #BURNBUSH_PAL
          sta object_pal,x
          lda #F_BURNBUSH
          sta object_frame,x
end

obj_forest_160a
        asm
          lda #<.plot_forest_160a
          sta object_spr_ptr_lo,x
          lda #>.plot_forest_160a
          sta object_spr_ptr_hi,x
          jmp .obj_next_stats
end

obj_firebat_stats
        asm
          ldx obj_index
          lda #FIREBAT_HP
          sta object_hp,x
          lda #FIREBAT_VEL_CAP_HI
          sta object_vel_cap_hi,x
          lda #FIREBAT_VEL_CAP_LO
          sta object_vel_cap_lo,x
          lda #FIREBAT_DAMAGE
          sta object_damage,x
          lda #FIREBAT_DEF
          sta object_def,x
          lda #FIREBAT_MDEF
          sta object_mdef,x
          lda #FIREBAT_FRICTION_HI
          sta object_friction_hi,x
          lda #FIREBAT_FRICTION_LO
          sta object_friction_lo,x
          lda #FIREBAT_SPEED_HI
          sta object_speed_hi,x
          lda #FIREBAT_SPEED_LO
          sta object_speed_lo,x
          lda #FIREBAT_FLAGS
          sta object_flags,x
          lda #<.plot_firebat
          sta object_spr_ptr_lo,x
          lda #>.plot_firebat
          sta object_spr_ptr_hi,x
          jmp .obj_next_stats
end

obj_forest_boss_stats
        asm
          ldx obj_index
          lda #255
          sta object_hp,x
          sta object_def,x
          sta object_mdef,x
          lda #F_ORB
          sta object_frame,x
          lda #ORB_PAL
          sta object_pal,x
          jmp .obj_forest_160a
end

plot_forest_160a
        plotsprite wolf0 sprite_pal Xposition Yposition frame
        goto plot_next

plot_firebat
        plotsprite firebat0 6 Xposition Yposition animation_frame
        goto plot_next

forest_waterfall
        ; prevent blacked out waterfalls when loading pal_animation rooms
        P7C1 = getfade(PAL_WFALL1) : P7C2 = getfade(PAL_WFALL2) : P7C3 = getfade(PAL_WFALL3)
        pal_animation = 1
        return

        data sfx_crystalchimes
        $10,$10,$00 ; version, priority, frames per chunk
        $03,$04,$05 ; first chunk of freq,channel,volume
        $03,$04,$0f
        $0c,$04,$05
        $0c,$04,$0d
        $0c,$04,$0f
        $0c,$04,$0b
        $0c,$04,$0f
        $0c,$04,$0f
        $06,$04,$0b
        $0c,$04,$0c
        $0c,$04,$0b
        $06,$04,$0a
        $03,$0c,$0d
        $03,$0c,$0b
        $03,$0c,$0a
        $03,$0c,$08
        $06,$04,$09
        $03,$0c,$0f
        $03,$0c,$0d
        $06,$04,$08
        $03,$0c,$0c
        $0a,$04,$07
        $0a,$04,$0a
        $0a,$04,$0d
        $03,$0c,$04
        $0a,$04,$07
        $06,$04,$06
        $0a,$04,$08
        $0a,$04,$0c
        $06,$04,$07
        $0a,$04,$04
        $0a,$04,$05
        $06,$04,$06
        $1e,$06,$02
        $06,$04,$05
        $0a,$04,$06
        $0a,$04,$06
        $06,$04,$05
        $0a,$04,$07
        $06,$04,$04
        $0a,$04,$05
        $0a,$04,$06
        $06,$04,$05
        $1e,$06,$01
        $00,$00,$00
end