load_forest
        if !first_load then forest_set_room
        first_load = 0
        if save_room_index = 1 then forest_save_1
        if save_room_index = 2 then forest_save_2
        if save_room_index = 3 then forest_save_3
        if save_room_index = 4 then forest_save_4
        if exit_room_index = F_FOREST_ARMOR_I then forest_armor
        if exit_room_index = F_FOREST_ARMOR_EXIT_I then forest_armor_exit
        if exit_room_index = F_FOREST_INN_I then forest_inn
        if exit_room_index = F_FOREST_INN_EXIT_I then forest_inn_exit
        if exit_room_index = F_FOREST_WITCH_I then forest_witch
        if exit_room_index = F_FOREST_WITCH_EXIT_I then forest_witch_exit
        if exit_room_index = F_FOREST_CATHEDRAL_I then forest_cathedral
        if exit_room_index = F_FOREST_START2_I then forest_start2
        if exit_room_index = F_FOREST_START3_I then forest_start3
  

; Initial player location on game start
forest_start
        room_index = 45
        menu_map_Xpos = 78
        menu_map_Ypos = 160
        player_Xpos = 9*8
        player_Ypos = $40
        player_facing = DIR_UP
        goto forest_set_room

forest_start2
        room_index    = F_FOREST_START2_I 
        menu_map_Xpos = M_FOREST_START2_X
        menu_map_Ypos = M_FOREST_START2_Y
        player_Xpos   = F_FOREST_START2_X
;       player_Ypos   = F_FOREST_START2_Y
;       player_facing = F_FOREST_START2_D
        goto forest_set_room

forest_start3
        room_index    = F_FOREST_START3_I 
        menu_map_Xpos = M_FOREST_START3_X
        menu_map_Ypos = M_FOREST_START3_Y
        player_Xpos   = F_FOREST_START3_X
;       player_Ypos   = F_FOREST_START3_Y
;       player_facing = F_FOREST_START3_D
        goto forest_set_room

forest_save_1
        room_index    = F_FOREST_SAVE1_I 
        menu_map_Xpos = M_FOREST_SAVE1_X
        menu_map_Ypos = M_FOREST_SAVE1_Y
        player_Xpos   = F_FOREST_SAVE1_X
        player_Ypos   = F_FOREST_SAVE1_Y
        player_facing = F_FOREST_SAVE1_D
        goto forest_set_room

forest_save_2
        room_index    = F_FOREST_SAVE2_I 
        menu_map_Xpos = M_FOREST_SAVE2_X
        menu_map_Ypos = M_FOREST_SAVE2_Y
        player_Xpos   = F_FOREST_SAVE2_X
        player_Ypos   = F_FOREST_SAVE2_Y
        player_facing = F_FOREST_SAVE2_D
        goto forest_set_room

forest_save_3
        room_index    = F_FOREST_SAVE3_I 
        menu_map_Xpos = M_FOREST_SAVE3_X
        menu_map_Ypos = M_FOREST_SAVE3_Y
        player_Xpos   = F_FOREST_SAVE3_X
        player_Ypos   = F_FOREST_SAVE3_Y
        player_facing = F_FOREST_SAVE3_D
        goto forest_set_room

forest_save_4
        room_index    = F_FOREST_SAVE4_I 
        menu_map_Xpos = M_FOREST_SAVE4_X
        menu_map_Ypos = M_FOREST_SAVE4_Y
        player_Xpos   = F_FOREST_SAVE4_X
        player_Ypos   = F_FOREST_SAVE4_Y
        player_facing = F_FOREST_SAVE4_D
        goto forest_set_room

forest_armor
        room_index = F_FOREST_ARMOR_I
        player_Xpos = F_FOREST_ARMOR_X
        player_Ypos = F_FOREST_ARMOR_Y
        goto forest_set_room

forest_armor_exit
        room_index = F_FOREST_ARMOR_EXIT_I
        player_Xpos = F_FOREST_ARMOR_EXIT_X
        player_Ypos = F_FOREST_ARMOR_EXIT_Y
        goto forest_set_room


forest_inn
        room_index = F_FOREST_INN_I
        player_Xpos = F_FOREST_INN_X
        player_Ypos = F_FOREST_INN_Y
        goto forest_set_room

forest_inn_exit
        room_index    = F_FOREST_INN_EXIT_I
        player_Xpos   = F_FOREST_INN_EXIT_X
        player_Ypos   = F_FOREST_INN_EXIT_Y
        player_facing = DIR_DOWN
        goto forest_set_room

forest_witch
        room_index = F_FOREST_WITCH_I
        player_Xpos = F_FOREST_WITCH_X
        player_Ypos = F_FOREST_WITCH_Y
        player_facing = DIR_UP
        goto forest_set_room

set_burnbush_name
        asm
          lda #<name_bush
          sta pickup_ptr_lo
          lda #>name_bush
          sta pickup_ptr_hi
          ldy #PICKUP_TIME
          sty pickup_timer
          ldy #1
          sty new_pickup
          sty item_pickup
          jmp .cc_next
end

        dmahole 0
forest_witch_exit
        room_index    = F_FOREST_WITCH_EXIT_I
        player_Xpos   = F_FOREST_WITCH_EXIT_X
        player_Ypos   = F_FOREST_WITCH_EXIT_Y
        player_facing = DIR_DOWN
        goto forest_set_room

forest_cathedral
        room_index    = F_FOREST_CATHEDRAL_I
        player_Xpos   = F_FOREST_CATHEDRAL_X
        player_Ypos   = F_FOREST_CATHEDRAL_Y
        player_facing = F_FOREST_CATHEDRAL_D
        goto forest_set_room

forest_set_room
        characterset forest_trees
        if music_playing then forest_init
        music_playing = 1
forest_init
        asm
          ldx #0
          stx no_flash
          stx alt_palette
          stx pal_animation
          stx exit_room_index
          stx save_room_index
          stx obscure_player
          stx alt_torch
          dex   ; $FF
          stx locked_zone
          ldx room_index
          lda forest_rooms,x
          tax
          lda forest_obj_lo,x
          sta pointer
          lda forest_obj_hi,x
          sta pointer_hi
          lda room_index
          asl
          sta menu_map_index
          clc
          adc #1
          sta menu_map_index_2
          cpx #5
          bcs .forest_room_b16
          jmp .forest_room_bank_2
end
forest_room_b16
        gosub forest_room_bank_16 bank16
        return thisbank

forest_room_bank_2
        asm
          lda forest_map_lo,x
          sta jump1
          lda forest_map_hi,x
          sta jump2
          jmp (jump1)
end

forest_pals
        asm
          lda flash_color
          sta P4C1
          sta P5C1
end
        if alt_palette then forest_interior
        P4C2 = getfade(PAL_F_DKGRN, black) : P4C3 = getfade(PAL_F_LTGRN)    ; greens used by trees and slimes
        P6C1 = flash_color : P6C2 = getfade(PAL_F_WATER, black) : P6C3 = getfade(PAL_F_LTWTR)    ; blue and gray used by water
forest_shared
        bg_color = getfade(PAL_F_GRND, black)
        ; bypass setting soft animated palette registers when pal_animation enabled so they don't reset
        if pal_animation then forest_shared_2
        sP7C1 = getfade(PAL_WFALL1) : sP7C2 = getfade(PAL_WFALL2) : sP7C3 = getfade(PAL_WFALL3)
forest_house
        ; include "house" palette
        P7C1 = flash_color : P7C2 = getfade(PAL_F_LTBRN) : P7C3 = getfade(PAL_F_HOUSE, black)    ; ledges, beige and light browns
forest_shared_2
        incbasic shared_pals.78b
        P5C2 = getfade(PAL_F_DKGRY)
        ; handle fade for rocks and wolves - gray always fades to black and makes them invisible with darkness
        if !fade then P5C3 = $01 else P5C3 = getfade(PAL_F_LTGRY)
        goto palette_done

forest_interior
        if alt_palette = 2 then forest_witch_pal
        P4C3 = getfade(PAL_C_LTCARP, black)
        P4C2 = getfade(PAL_C_DKCARP, black)
        goto forest_shared

forest_witch_pal
        P4C3 = getfade(PAL_W_LTCARP, black)
        P4C2 = getfade(PAL_W_DKCARP, black)
        P6C1 = getfade(PAL_FIREBAT_DK, black)
        P6C2 = getfade(PAL_FIREBAT_MD)
        P6C3 = getfade(PAL_FIREBAT_LT)
        P7C2 = getfade(PAL_W_LTBRN)
        P7C3 = getfade(PAL_W_HOUSE, black)
        bg_color = getfade(PAL_W_DKBRN, black)
        goto forest_shared_2

plot_forest_room_0
plot_forest_room_1
        menu_map_room[menu_map_index] = ROOML_UL
        menu_map_room[menu_map_index_2] = ROOMR_UR
        plotmapfile tiled/forest_room_1.tmx forest_room_1 0 1 20 12
        memcpy map12 forest_room_1 240
        return thisbank


plot_forest_room_2
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UD
        plotmapfile tiled/forest_room_2.tmx forest_room_2 0 1 20 12
        memcpy map12 forest_room_2 240
        return thisbank

plot_forest_room_3
        pw_success = 0
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_3.tmx forest_room_3 0 1 20 12
        memcpy map12 forest_room_3 240
        return thisbank

plot_forest_room_4
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_4.tmx forest_room_4 0 1 20 12
        memcpy map12 forest_room_4 240
        return thisbank

