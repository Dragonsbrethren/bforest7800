;==============================================================================
; BANK 2
;------------------------------------------------------------------------------
; Contains forest tileset graphics, maps, and enemy AI
;==============================================================================
        bank 2
        incbasic forest.78b

        data forest_map_lo
        plot_forest_room_0_lo, plot_forest_room_1_lo, plot_forest_room_2_lo, plot_forest_room_3_lo, plot_forest_room_4_lo,
        plot_forest_room_5_lo, plot_forest_room_6_lo, plot_forest_room_7_lo, plot_forest_room_8_lo, plot_forest_room_9_lo,
        plot_forest_room_10_lo, plot_forest_room_11_lo, plot_forest_room_12_lo, plot_forest_room_13_lo, plot_forest_room_14_lo,
        plot_forest_room_15_lo, plot_forest_room_16_lo, plot_forest_room_17_lo, plot_forest_room_18_lo, plot_forest_room_19_lo,
        plot_forest_room_20_lo, plot_forest_room_21_lo, plot_forest_room_22_lo, plot_forest_room_23_lo
end

        data forest_map_hi
        plot_forest_room_0_hi, plot_forest_room_1_hi, plot_forest_room_2_hi, plot_forest_room_3_hi, plot_forest_room_4_hi,
        plot_forest_room_5_hi, plot_forest_room_6_hi, plot_forest_room_7_hi, plot_forest_room_8_hi, plot_forest_room_9_hi,
        plot_forest_room_10_hi, plot_forest_room_11_hi, plot_forest_room_12_hi, plot_forest_room_13_hi, plot_forest_room_14_hi,
        plot_forest_room_15_hi, plot_forest_room_16_hi, plot_forest_room_17_hi, plot_forest_room_18_hi, plot_forest_room_19_hi,
        plot_forest_room_20_hi, plot_forest_room_21_hi, plot_forest_room_22_hi, plot_forest_room_23_hi
end

        data forest_obj_lo
        forest_room_0_obj_lo, forest_room_1_obj_lo, forest_room_2_obj_lo, forest_room_3_obj_lo, forest_room_4_obj_lo,
        forest_room_5_obj_lo, forest_room_6_obj_lo, forest_room_7_obj_lo, forest_room_8_obj_lo, forest_room_9_obj_lo,
        forest_room_10_obj_lo, forest_room_11_obj_lo, forest_room_12_obj_lo, forest_room_13_obj_lo, forest_room_14_obj_lo,
        forest_room_15_obj_lo, forest_room_16_obj_lo, forest_room_17_obj_lo, forest_room_18_obj_lo, forest_room_19_obj_lo,
        forest_room_20_obj_lo, forest_room_21_obj_lo, forest_room_22_obj_lo, forest_room_23_obj_lo
end

        data forest_obj_hi
        forest_room_0_obj_hi, forest_room_1_obj_hi, forest_room_2_obj_hi, forest_room_3_obj_hi, forest_room_4_obj_hi,
        forest_room_5_obj_hi, forest_room_6_obj_hi, forest_room_7_obj_hi, forest_room_8_obj_hi, forest_room_9_obj_hi,
        forest_room_10_obj_hi, forest_room_11_obj_hi, forest_room_12_obj_hi, forest_room_13_obj_hi, forest_room_14_obj_hi,
        forest_room_15_obj_hi, forest_room_16_obj_hi, forest_room_17_obj_hi, forest_room_18_obj_hi, forest_room_19_obj_hi,
        forest_room_20_obj_hi, forest_room_21_obj_hi, forest_room_22_obj_hi, forest_room_23_obj_hi
end

load_forest
        if !first_load then forest_set_room
        first_load = 0
        if save_room_index = 1 then forest_save_1
        if exit_room_index = F_FOREST_INN_I then forest_inn
        if exit_room_index = F_FOREST_INN_EXIT_I then forest_inn_exit

; Initial player location on game start
        room_index = 38
        menu_map_Xpos = 78
        menu_map_Ypos = 144
        player_Xpos = 9*8
        player_Ypos = $A0
        player_facing = DIR_UP
        goto forest_set_room

forest_save_1
        room_index = 12
        menu_map_Xpos = 94
        menu_map_Ypos = 80
        player_Xpos = 24
        player_Ypos = 60
        player_facing = DIR_DOWN
        goto forest_set_room

forest_inn
        room_index = F_FOREST_INN_I
        player_Xpos = 9*8
        player_Ypos = $A0
        player_facing = DIR_UP
        goto forest_set_room

forest_inn_exit
        room_index    = F_FOREST_INN_EXIT_I
        player_Xpos   = F_FOREST_INN_EXIT_X
        player_Ypos   = F_FOREST_INN_EXIT_Y
        player_facing = DIR_DOWN
        goto forest_set_room

forest_set_room
        characterset forest_trees
        if music_playing then forest_init
        music_playing = 1
forest_init
        asm
          lda #0
          sta no_flash
          sta alt_palette
          sta pal_animation
          sta exit_room_index
          sta save_room_index
          sta obscure_player
          lda #$FF
          sta locked_zone
          ldx room_index
          lda forest_rooms,x
          tax
          lda forest_obj_lo,x
          sta pointer
          lda forest_obj_hi,x
          sta pointer_hi
          lda room_index
          asl
          sta menu_map_index
          clc
          adc #1
          sta menu_map_index_2
          cpx #12
          bcc .forest_room_bank_2
end
        gosub forest_room_bank_16 bank16
        return thisbank

forest_room_bank_2
        asm
          lda forest_map_lo,x
          sta jump1
          lda forest_map_hi,x
          sta jump2
          jmp (jump1)
end

forest_pals
        asm
          lda flash_color
          sta P4C1
          sta P5C1
          sta P7C1
end
        if alt_palette  then forest_interior
        P4C2 = getfade(PAL_F_DKGRN, black) : P4C3 = getfade(PAL_F_LTGRN)    ; greens used by trees and slimes
        P6C1 = flash_color : P6C2 = getfade(PAL_F_WATER, black) : P6C3 = getfade(PAL_F_LTWTR)    ; blue and gray used by water
forest_shared
        ; include "house" palette
        bg_color = getfade(PAL_F_GRND, black)
        P7C2 = getfade(PAL_F_LTBRN) : P7C3 = getfade(PAL_F_HOUSE, black)    ; ledges, beige and light browns
forest_shared_2
        incbasic shared_pals.78b
        P5C2 = getfade(PAL_F_DKGRY)
        ; handle fade for rocks and wolves - gray always fades to black and makes them invisible with darkness
        if !fade then P5C3 = $01 else P5C3 = getfade(PAL_F_LTGRY)
        
        goto palette_done

forest_interior
        if alt_palette = 2 then forest_witch
        P4C3 = getfade(PAL_C_LTCARP, black)
        P4C2 = getfade(PAL_C_DKCARP, black)
        goto forest_shared

forest_witch
        P4C3 = PAL_W_LTCARP
        P4C2 = PAL_W_DKCARP
        P6C1 = PAL_FIREBAT_DK
        P6C2 = PAL_FIREBAT_MD
        P6C3 = PAL_FIREBAT_LT
        P7C2 = getfade(PAL_W_LTBRN)
        P7C3 = getfade(PAL_W_HOUSE, black)
        bg_color = getfade(PAL_W_DKBRN, black)
        goto forest_shared_2

plot_forest_room_0
plot_forest_room_1
        menu_map_room[menu_map_index] = ROOML_UL
        menu_map_room[menu_map_index_2] = ROOMR_UR
        plotmapfile tiled/forest_room_1.tmx forest_room_1 0 1 20 12
        memcpy map12 forest_room_1 240
        return thisbank


plot_forest_room_2
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UD
        plotmapfile tiled/forest_room_2.tmx forest_room_2 0 1 20 12
        memcpy map12 forest_room_2 240
        return thisbank

plot_forest_room_3
        pw_success = 0
        menu_map_room[menu_map_index] = $0E
        menu_map_room[menu_map_index_2] = $09
        plotmapfile tiled/forest_room_3.tmx forest_room_3 0 1 20 12
        memcpy map12 forest_room_3 240
        return thisbank

plot_forest_room_4
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_4.tmx forest_room_4 0 1 20 12
        memcpy map12 forest_room_4 240
        return thisbank

plot_forest_room_5
        menu_map_room[menu_map_index] = ROOML_UL
        menu_map_room[menu_map_index_2] = ROOMR_U
        plotmapfile tiled/forest_room_5.tmx forest_room_5 0 1 20 12
        memcpy map12 forest_room_5 240
        return thisbank

plot_forest_room_6
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_6.tmx forest_room_6 0 1 20 12
        memcpy map12 forest_room_6 240
        return thisbank

plot_forest_room_7
        menu_map_room[menu_map_index] = 6
        menu_map_room[menu_map_index_2] = 7
        plotmapfile tiled/forest_room_7.tmx forest_room_7 0 1 20 12
        memcpy map12 forest_room_7 240
        return thisbank

plot_forest_room_8
        menu_map_room[menu_map_index] = $10
        menu_map_room[menu_map_index_2] = 5
        plotmapfile tiled/forest_room_8.tmx forest_room_8 0 1 20 12
        memcpy map12 forest_room_8 240
        return thisbank

plot_forest_room_9
        menu_map_room[menu_map_index] = ROOML_D
        menu_map_room[menu_map_index_2] = ROOMR_D
        plotmapfile tiled/forest_room_9.tmx forest_room_9 0 1 20 12
        memcpy map12 forest_room_9 240
        return thisbank

plot_forest_room_10
        menu_map_room[menu_map_index] = ROOML_U
        menu_map_room[menu_map_index_2] = ROOMR_UR
        plotmapfile tiled/forest_room_10.tmx forest_room_10 0 1 20 12
        memcpy map12 forest_room_10 240
        return thisbank

        dmahole 0
plot_forest_room_11
        if !pw_success then in_save_room = 1
        pw_success = 0
        save_room_index = 1
        entered_save_room{0} = 1
        menu_map_room[menu_map_index]   = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_11.tmx forest_room_11 0 1 20 12
        memcpy map12 forest_room_11 240
        return thisbank

plot_forest_room_12
        menu_map_room[menu_map_index] = $08
        menu_map_room[menu_map_index_2] = $0F
        plotmapfile tiled/forest_room_12.tmx forest_room_12 0 1 20 12
        memcpy map12 forest_room_12 240
        return thisbank

        data forest_room_0_obj
        $00
end

        data forest_room_1_obj
        $00
end

        data forest_room_2_obj
        TYPE_TORCH, $28, $9D,  TYPE_TORCH, $6F, $9D,  TYPE_RAVEN, $1E, $28,  TYPE_SLIME, $51, $58,
        $00
end

        data forest_room_3_obj
        TYPE_NIXTAIL, $4E, $40,  $00
end

