        return otherbank

plot_forest_room_20
        plotmapfile tiled/forest_room_20.tmx forest_room_20 0 1 20 12
        memcpy map12 forest_room_20 240
        alt_palette = 1
        exit_tileset = T_FOREST
        exit_Xpos = 9*8
        exit_Ypos = $B0
        exit_room_index = F_FOREST_INN_EXIT_I
        return otherbank

plot_forest_room_21
        if !pw_success then in_save_room = 1
        pw_success = 0
        save_room_index = 3
        ; inn room toggles on its normal map square
        menu_map_room[76] = ROOML_UDL
        menu_map_room[77] = ROOMR_UDR
        plotmapfile tiled/forest_room_21.tmx forest_room_21 0 1 20 12
        memcpy map12 forest_room_21 240
        asm
          lda #1
          sta alt_palette
          sta alt_torch
end
        exit_tileset = T_FOREST
        exit_Xpos = 7*8
        exit_Ypos = $B0
        exit_room_index = F_FOREST_INN_EXIT_I
        return otherbank

plot_forest_room_22
        if !pw_success then in_save_room = 1
        pw_success = 0
        save_room_index = 3
        ; inn room toggles on its normal map square
        menu_map_room[78] = ROOML_UL
        menu_map_room[79] = ROOMR_U
