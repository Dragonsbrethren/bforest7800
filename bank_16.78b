;==============================================================================
; BANK 16
;------------------------------------------------------------------------------
; Contains forest tileset graphics, maps, and enemy AI
;==============================================================================
        bank 16
        incbasic forest.78b

        data forest_map_b16_lo
        plot_forest_room_0_lo, plot_forest_room_1_lo, plot_forest_room_2_lo, plot_forest_room_3_lo, plot_forest_room_4_lo,
        plot_forest_room_5_lo, plot_forest_room_6_lo, plot_forest_room_7_lo, plot_forest_room_8_lo, plot_forest_room_9_lo,
        plot_forest_room_10_lo, plot_forest_room_11_lo, plot_forest_room_12_lo, plot_forest_room_13_lo, plot_forest_room_14_lo,
        plot_forest_room_15_lo, plot_forest_room_16_lo, plot_forest_room_17_lo, plot_forest_room_18_lo, plot_forest_room_19_lo,
        plot_forest_room_20_lo, plot_forest_room_21_lo, plot_forest_room_22_lo, plot_forest_room_23_lo, plot_forest_room_24_lo,
        plot_forest_room_25_lo, plot_forest_room_26_lo, plot_forest_room_28_lo, plot_forest_room_29_lo, plot_forest_room_30_lo,
        plot_forest_room_31_lo
end

        data forest_map_b16_hi
        plot_forest_room_0_hi, plot_forest_room_1_hi, plot_forest_room_2_hi, plot_forest_room_3_hi, plot_forest_room_4_hi,
        plot_forest_room_5_hi, plot_forest_room_6_hi, plot_forest_room_7_hi, plot_forest_room_8_hi, plot_forest_room_9_hi,
        plot_forest_room_10_hi, plot_forest_room_11_hi, plot_forest_room_12_hi, plot_forest_room_13_hi, plot_forest_room_14_hi,
        plot_forest_room_15_hi, plot_forest_room_16_hi, plot_forest_room_17_hi, plot_forest_room_18_hi, plot_forest_room_19_hi,
        plot_forest_room_20_hi, plot_forest_room_21_hi, plot_forest_room_22_hi, plot_forest_room_23_hi, plot_forest_room_24_hi,
        plot_forest_room_25_hi, plot_forest_room_26_hi, plot_forest_room_28_hi, plot_forest_room_29_hi, plot_forest_room_30_hi,
        plot_forest_room_31_hi
end

forest_room_bank_16
        asm
          lda forest_map_b16_lo,x
          sta jump1
          lda forest_map_b16_hi,x
          sta jump2
          jmp (jump1)
end

        dmahole 0
plot_forest_room_11
        if !pw_success then in_save_room = 1
        pw_success = 0
        if room_index = F_FOREST_SAVE1_I then save_room_index = 1 : entered_save_room{0} = 1 else save_room_index = 2 : entered_save_room{1} = 1
        menu_map_room[menu_map_index]   = ROOML_D
        menu_map_room[menu_map_index_2] = ROOMR_DR
        plotmapfile tiled/forest_room_11.tmx forest_room_11 0 1 20 12
        memcpy map12 forest_room_11 240
        return thisbank

plot_forest_room_12
        menu_map_room[menu_map_index] = ROOML_UL
        menu_map_room[menu_map_index_2] = ROOMR_UR 
        plotmapfile tiled/forest_room_12.tmx forest_room_12 0 1 20 12
        memcpy map12 forest_room_12 240
        return thisbank

plot_forest_room_13
        ; use this map for toggling the "S" save marker
        entered_save_room{2} = 1
        menu_map_room[menu_map_index] = ROOML_UDL
        menu_map_room[menu_map_index_2] = ROOMR_UDR
        plotmapfile tiled/forest_room_13.tmx forest_room_13 0 1 20 12
        memcpy map12 forest_room_13 240
        exit_tileset = T_FOREST
        exit_Xpos = 14*8
        exit_Ypos = $70
        exit_room_index = F_FOREST_INN_I
        return otherbank

plot_forest_room_14
        menu_map_room[menu_map_index] = ROOML_UL
        menu_map_room[menu_map_index_2] = ROOMR_U
        plotmapfile tiled/forest_room_14.tmx forest_room_14 0 1 20 12
        memcpy map12 forest_room_14 240
        return otherbank

